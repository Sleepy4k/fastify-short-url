<!DOCTYPE html>
<html lang="id" class="h-full bg-gray-950">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= url && url.title ? url.title + ' - ' : '' %>Link Terproteksi</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#CC0000" />
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
  <link rel="stylesheet" href="/assets/css/app.css" />
  <script src="/assets/js/vendor/tailwind.cdn.js"></script>
</head>

<body class="min-h-screen bg-gray-950 text-gray-100 flex items-center justify-center p-4">
  <div class="w-full max-w-sm">
    <div class="rounded-2xl border border-gray-800 bg-gray-900 p-8 shadow-2xl">
      <div class="flex flex-col items-center mb-6">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl mb-4" style="background: linear-gradient(135deg, #CC0000, #990000);">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h1 class="text-xl font-bold text-white text-center">Link Terproteksi</h1>
        <% if (url && url.title) { %>
        <p class="text-sm text-gray-400 mt-1 text-center font-medium"><%= url.title %></p>
        <% } %>
        <p class="text-sm text-gray-500 mt-2 text-center">
          Masukkan password untuk mengakses link ini
        </p>
      </div>

      <% if (error) { %>
      <div class="mb-4 rounded-lg bg-red-900/50 border border-red-700 px-4 py-3 text-sm text-red-300">
        <%= error %>
      </div>
      <% } %>

      <form method="POST" action="/<%= code %>" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-gray-300 mb-1.5">Password</label>
          <input type="password" name="password" required autofocus placeholder="Masukkan password..." class="input-focus w-full rounded-xl bg-gray-800 border border-gray-700 px-4 py-3 text-sm focus:outline-none transition-all placeholder-gray-500" />
        </div>
        <button type="submit" class="w-full rounded-xl py-3 text-sm font-semibold text-white transition-all hover:brightness-110 active:scale-95" style="background: linear-gradient(135deg, #CC0000, #990000)">
          Buka Link
        </button>
      </form>

      <p class="text-xs text-gray-600 text-center mt-5">
        <a href="/" class="hover:text-gray-400 transition-colors">← Kembali ke beranda</a>
      </p>
    </div>
  </div>
</body>

</html>