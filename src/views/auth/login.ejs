<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - <%= appName %></title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#CC0000" />
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
  <link rel="apple-touch-icon" href="/assets/images/logo.png" />
  <link rel="stylesheet" href="/assets/css/login.css" />
  <script src="/assets/js/vendor/tailwind.cdn.js"></script>
  <script src="/assets/js/vendor/htmx.min.js" defer></script>
  <script src="/assets/js/page/login.js" defer></script>
</head>

<body>
  <div class="login-card">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-4 shadow-lg" style="background: linear-gradient(135deg, #CC0000, #990000);">
        <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-white"><%= appName %></h1>
      <p class="mt-1 text-sm text-gray-400">Masuk ke panel admin</p>
    </div>

    <div id="login-error" class="mb-4">
      <% if (typeof error !== 'undefined' && error) { %>
      <%- include('partials/login-error.ejs', { error }) %>
      <% } %>
    </div>

    <form hx-post="/login" hx-target="#login-error" hx-swap="innerHTML" class="space-y-4">
      <div>
        <label class="block text-sm font-semibold text-gray-300 mb-1.5" for="username">Username</label>
        <input id="username" name="username" type="text" required autocomplete="username" class="w-full rounded-xl bg-gray-800 border border-gray-700 px-4 py-3 text-sm focus:outline-none transition-all" onfocus="this.style.borderColor='#CC0000'; this.style.boxShadow='0 0 0 3px rgba(204,0,0,0.25)'" onblur="this.style.borderColor=''; this.style.boxShadow=''" placeholder="admin" />
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-300 mb-1.5" for="password">Password</label>
        <input id="password" name="password" type="password" required autocomplete="current-password" class="w-full rounded-xl bg-gray-800 border border-gray-700 px-4 py-3 text-sm focus:outline-none transition-all" onfocus="this.style.borderColor='#CC0000'; this.style.boxShadow='0 0 0 3px rgba(204,0,0,0.25)'" onblur="this.style.borderColor=''; this.style.boxShadow=''" placeholder="••••••••" />
      </div>
      <button type="submit" class="w-full rounded-xl px-4 py-3 text-sm font-semibold text-white transition-all hover:brightness-110 active:scale-[.98] shadow-md" style="background: linear-gradient(135deg, #CC0000, #990000);">
        Masuk
      </button>
    </form>

    <p class="mt-6 text-center text-xs text-gray-600">
      Naka URL Shortener
    </p>
  </div>

  <div id="toast-container" style="position:fixed;top:1rem;right:1rem;z-index:100;display:flex;flex-direction:column;gap:0.5rem;align-items:flex-end;pointer-events:none;"></div>
</body>

</html>