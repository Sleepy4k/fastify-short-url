<%- include('create-form.ejs') %>

<section id="url-list" hx-get="/admin/urls" hx-trigger="urlCreated from:body, urlUpdated from:body, urlDeleted from:body" hx-select="#url-list" hx-swap="outerHTML" hx-target="#url-list">
  <div class="rounded-xl border border-gray-800 overflow-hidden shadow-lg table-responsive">
    <table class="w-full text-sm min-w-[640px]">
      <thead class="bg-gray-900 text-gray-300 uppercase text-xs font-semibold">
        <tr>
          <th class="px-4 py-3 text-left">Shortcode</th>
          <th class="px-4 py-3 text-left hide-sm">URL Tujuan</th>
          <th class="px-4 py-3 text-center">Klik</th>
          <th class="px-4 py-3 text-center">Aktif</th>
          <th class="px-4 py-3 text-center hide-sm">Expired</th>
          <th class="px-4 py-3 text-center">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800 bg-gray-950">
        <% for (const url of urls) { %>
        <tr class="hover:bg-gray-900/50 transition-colors">
          <td class="px-4 py-3 font-mono font-semibold text-red-400">
            <a href="<%= baseUrl %>/<%= url.shortcode %>" target="_blank" rel="noopener" class="hover:underline">
              /<%= url.shortcode %>
            </a>
          </td>
          <td class="px-4 py-3 max-w-[200px] truncate text-gray-400 text-xs hide-sm" title="<%= url.originalUrl %>">
            <%= url.originalUrl.substring(0, 50) %><% if (url.originalUrl.length > 50) { %>…<% } %>
          </td>
          <td class="px-4 py-3 text-center font-bold text-green-400"><%= url.totalClicks %></td>
          <td class="px-4 py-3 text-center">
            <input type="checkbox" id="active-<%= url.id %>" <%= url.isActive ? 'checked' : '' %> class="h-4 w-4 cursor-pointer rounded" style="accent-color: #CC0000;" onchange="toggleUrlActive(<%= url.id %>, this.checked)" />
          </td>
          <td class="px-4 py-3 text-center text-xs text-gray-400 hide-sm">
            <%= url.expiresAt ? new Date(url.expiresAt).toLocaleDateString('id-ID') : '—' %>
          </td>
          <td class="px-4 py-3 text-center">
            <div class="flex items-center justify-center gap-1 flex-wrap">
              <button hx-get="/admin/urls/<%= url.id %>/edit" hx-target="#modal-container" hx-swap="innerHTML" hx-select="#edit-modal" class="text-xs px-2.5 py-1.5 rounded-lg text-gray-300 hover:text-white hover:bg-gray-700 border border-gray-700 hover:border-gray-500 transition-all">
                Edit
              </button>
              <button hx-get="/admin/urls/<%= url.id %>/qr" hx-target="#modal-container" hx-swap="innerHTML" hx-select="#qr-modal" class="text-xs px-2.5 py-1.5 rounded-lg text-gray-300 hover:text-white hover:bg-gray-700 border border-gray-700 hover:border-gray-500 transition-all">
                QR
              </button>
              <button hx-get="/admin/analytics/<%= url.id %>" hx-target="#panel" hx-swap="innerHTML" hx-push-url="/admin/analytics/<%= url.id %>" hx-select="#analytics-detail" onclick="activateTab('analytics')" class="text-xs px-2.5 py-1.5 rounded-lg text-blue-400 hover:text-white hover:bg-blue-900/30 border border-blue-900/50 hover:border-blue-700 transition-all">
                Stat
              </button>
              <span id="del-url-<%= url.id %>" hx-delete="/admin/urls/<%= url.id %>" hx-trigger="confirmed" hx-swap="none" class="hidden"></span>
              <button onclick="confirmDeleteUrl(<%= url.id %>, '<%= url.shortcode %>')" class="text-xs px-2.5 py-1.5 rounded-lg text-red-400 hover:text-white hover:bg-red-900/30 border border-red-900/50 hover:border-red-700 transition-all">
                Hapus
              </button>
            </div>
          </td>
        </tr>
        <% } %>
        <% if (!urls.length) { %>
        <tr>
          <td colspan="6" class="px-6 py-16 text-center text-gray-500 text-sm">
            Belum ada shortlink. Buat yang pertama di atas!
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% const totalPages = Math.ceil(total / limit); %>
  <% if (totalPages > 1) { %>
  <div class="mt-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-gray-400">
    <span>Menampilkan <%= (page - 1) * limit + 1 %>-<%= Math.min(page * limit, total) %> dari <%= total %> shortlink</span>
    <div class="flex gap-2">
      <% if (page > 1) { %>
      <button hx-get="/admin/urls?page=<%= page - 1 %>&limit=<%= limit %>" hx-target="#url-list" hx-select="#url-list" hx-swap="outerHTML" class="rounded-lg bg-gray-800 hover:bg-gray-700 px-4 py-2 transition-colors text-xs font-medium">
        &larr; Sebelumnya
      </button>
      <% } %>
      <% if (page < totalPages) { %>
      <button hx-get="/admin/urls?page=<%= page + 1 %>&limit=<%= limit %>" hx-target="#url-list" hx-select="#url-list" hx-swap="outerHTML" class="rounded-lg bg-gray-800 hover:bg-gray-700 px-4 py-2 transition-colors text-xs font-medium">
        Berikutnya &rarr;
      </button>
      <% } %>
    </div>
  </div>
  <% } %>
</section>

<script>
  function toggleUrlActive(id, isActive) {
    htmx.ajax('PATCH', '/admin/urls/' + id, {
      swap: 'none',
      values: {
        isActive: String(isActive)
      }
    });
  }
</script>