<%
const _ctotalPages = Math.ceil(totalClicks / clicksLimit);
let _cstartPage = Math.max(1, clicksPage - 2);
let _cendPage = Math.min(_ctotalPages, _cstartPage + 4);
if (_cendPage - _cstartPage < 4) _cstartPage = Math.max(1, _cendPage - 4);
%>
<div id="analytics-detail" class="space-y-5">
  <div>
    <button hx-get="/admin/analytics" hx-target="#panel" hx-swap="innerHTML" hx-push-url="/admin/analytics" class="inline-flex items-center gap-2 text-sm font-semibold text-red-400 hover:text-red-300 px-3 py-2 rounded-xl hover:bg-red-900/20 transition-all" type="button">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Kembali ke Analytics
    </button>
  </div>

  <div class="bg-gray-900 rounded-xl border border-gray-800 p-4 sm:p-5">
    <p class="text-xs text-gray-500 mb-1">Analytics untuk</p>
    <h2 class="text-base sm:text-lg font-bold text-gray-100 break-all">
      <a href="<%= baseUrl %>/<%= url.shortcode %>" target="_blank" rel="noopener" class="font-mono text-red-400 hover:underline"><%= baseUrl %>/<%= url.shortcode %></a>
    </h2>
    <p class="text-xs text-gray-500 mt-1 truncate"><%= url.originalUrl %></p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-4">
      <p class="text-xs text-gray-400 mb-1">Total Klik</p>
      <p class="text-2xl font-bold text-green-400"><%= url.totalClicks %></p>
    </div>
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-4">
      <p class="text-xs text-gray-400 mb-1">Unique Klik</p>
      <p class="text-2xl font-bold text-blue-400"><%= uniqueClicks %></p>
    </div>
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-4">
      <p class="text-xs text-gray-400 mb-1">Dibuat</p>
      <p class="text-sm font-semibold text-gray-200"><%= new Date(url.createdAt).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %></p>
    </div>
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-4">
      <p class="text-xs text-gray-400 mb-1">Status</p>
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2 py-1 rounded-full <%= url.isActive ? 'bg-green-900/50 text-green-300 border border-green-700' : 'bg-red-900/50 text-red-300 border border-red-700' %>">
        <span class="w-1.5 h-1.5 rounded-full <%= url.isActive ? 'bg-green-400' : 'bg-red-400' %>"></span>
        <%= url.isActive ? 'Aktif' : 'Nonaktif' %>
      </span>
    </div>
  </div>

  <div class="rounded-xl bg-gray-900 border border-yellow-800/50 p-4 sm:p-5">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-yellow-900/40 border border-yellow-700/50 flex items-center justify-center">
          <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-yellow-200">Reset Analytics</p>
          <p class="text-xs text-gray-400 mt-0.5">Hapus semua data klik untuk shortlink ini secara permanen. Data tidak dapat dipulihkan.</p>
        </div>
      </div>

      <span id="reset-analytics-<%= url.id %>" hx-delete="/admin/analytics/<%= url.id %>/reset" hx-trigger="confirmed" hx-swap="none" class="hidden"></span>
      <button onclick="confirmResetAnalytics(<%= url.id %>, '<%= url.shortcode %>')" class="flex-shrink-0 inline-flex items-center gap-2 rounded-xl border border-yellow-700 bg-yellow-900/30 hover:bg-yellow-900/60 text-yellow-200 px-4 py-2 text-sm font-semibold transition-all hover:shadow-lg">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        Reset Analytics
      </button>
    </div>
  </div>

  <% if (clicksByDay.length) { %>
  <div class="rounded-xl border border-gray-800 bg-gray-900 p-4 sm:p-5">
    <h3 class="text-sm font-bold mb-4 text-gray-100">Klik per Hari (30 hari terakhir)</h3>
    <div class="space-y-1.5">
      <% const maxDay = Math.max(...clicksByDay.map(d => d.count)); %>
      <% for (const day of clicksByDay) { %>
      <div class="flex items-center gap-2 text-xs">
        <span class="w-24 sm:w-28 text-gray-400 shrink-0 text-right"><%= day.day %></span>
        <div class="flex-1 bg-gray-800 rounded-full h-2.5 min-w-0">
          <div class="h-2.5 rounded-full transition-all" style="width: <%= maxDay > 0 ? Math.round((day.count / maxDay) * 100) : 0 %>%; background: linear-gradient(90deg, #CC0000, #ff4040);"></div>
        </div>
        <span class="w-8 text-right font-bold font-mono text-red-300 shrink-0"><%= day.count %></span>
      </div>
      <% } %>
    </div>
  </div>
  <% } %>

  <div class="rounded-xl border border-gray-800 overflow-hidden">
      <h3 class="text-sm font-bold text-gray-100">Riwayat Klik</h3>
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-500">Total <strong class="text-gray-300"><%= totalClicks %></strong> klik</span>
        <div class="relative">
          <select id="clicks-limit-select" class="appearance-none rounded-lg bg-gray-800 border border-gray-700 px-2.5 pr-7 py-1.5 text-xs text-gray-300 focus:outline-none cursor-pointer hover:bg-gray-700 transition-colors" onchange="changeClicksLimit(this.value, <%= url.id %>)">
            <% for (const n of [10, 20, 50]) { %>
            <option value="<%= n %>" <%= clicksLimit === n ? 'selected' : '' %>><%= n %> / hal</option>
            <% } %>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-1.5 flex items-center">
            <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table id="clicks-table" class="w-full text-xs min-w-[640px]">
        <thead class="bg-gray-900/80 text-gray-400 uppercase font-semibold">
          <tr>
            <th class="px-4 py-2.5 text-left">Waktu</th>
            <th class="px-4 py-2.5 text-left">IP</th>
            <th class="px-4 py-2.5 text-left">Perangkat</th>
            <th class="px-4 py-2.5 text-left">Browser</th>
            <th class="px-4 py-2.5 text-left hide-sm">OS</th>
            <th class="px-4 py-2.5 text-left hide-sm">Referer</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% for (const click of recentClicks) { %>
          <tr class="hover:bg-gray-900/50 transition-colors" data-ua="<%= encodeURIComponent(click.userAgent || '') %>">
            <td class="px-4 py-2.5 text-gray-400 whitespace-nowrap">
              <%= new Date(click.clickedAt).toLocaleString('id-ID') %>
            </td>
            <td class="px-4 py-2.5 font-mono text-gray-400 max-w-[120px] truncate" title="<%= click.ipAddress || '' %>">
              <%= click.ipAddress || '—' %>
            </td>
            <td class="px-4 py-2.5 text-gray-400 ua-device">—</td>
            <td class="px-4 py-2.5 text-gray-400 ua-browser">—</td>
            <td class="px-4 py-2.5 text-gray-400 ua-os hide-sm">—</td>
            <td class="px-4 py-2.5 text-gray-400 max-w-[140px] truncate hide-sm" title="<%= click.referer || '' %>"><%= click.referer || '—' %></td>
          </tr>
          <% } %>
          <% if (!recentClicks.length) { %>
          <tr>
            <td colspan="6" class="px-4 py-10 text-center text-gray-500">Belum ada klik yang tercatat.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Clicks pagination -->
    <% if (_ctotalPages > 1) { %>
    <div class="px-4 py-3 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-3">
      <span class="text-xs text-gray-500">Halaman <strong class="text-gray-300"><%= clicksPage %></strong> dari <strong class="text-gray-300"><%= _ctotalPages %></strong></span>
      <div class="flex items-center gap-1">
        <% if (clicksPage > 1) { %>
        <button hx-get="/admin/analytics/<%= url.id %>?clicksPage=<%= clicksPage - 1 %>&clicksLimit=<%= clicksLimit %>" hx-target="#panel" hx-swap="innerHTML" hx-select="#analytics-detail" class="flex items-center gap-1 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 px-3 py-1.5 text-xs font-medium text-gray-300 hover:text-white transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg> Prev
        </button>
        <% } %>

        <% if (_cstartPage > 1) { %>
        <button hx-get="/admin/analytics/<%= url.id %>?clicksPage=1&clicksLimit=<%= clicksLimit %>" hx-target="#panel" hx-swap="innerHTML" hx-select="#analytics-detail" class="rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 w-8 py-1.5 text-xs font-medium text-gray-300 text-center">1</button>
        <% if (_cstartPage > 2) { %><span class="text-gray-600 px-1 text-xs">…</span><% } %>
        <% } %>

        <% for (let p = _cstartPage; p <= _cendPage; p++) { %>
        <button hx-get="/admin/analytics/<%= url.id %>?clicksPage=<%= p %>&clicksLimit=<%= clicksLimit %>" hx-target="#panel" hx-swap="innerHTML" hx-select="#analytics-detail" class="rounded-lg border w-8 py-1.5 text-xs font-medium transition-colors text-center <%= p === clicksPage ? 'bg-red-700 border-red-600 text-white' : 'bg-gray-800 hover:bg-gray-700 border-gray-700 text-gray-300 hover:text-white' %>">
          <%= p %>
        </button>
        <% } %>

        <% if (_cendPage < _ctotalPages) { %>
        <% if (_cendPage < _ctotalPages - 1) { %><span class="text-gray-600 px-1 text-xs">…</span><% } %>
        <button hx-get="/admin/analytics/<%= url.id %>?clicksPage=<%= _ctotalPages %>&clicksLimit=<%= clicksLimit %>" hx-target="#panel" hx-swap="innerHTML" hx-select="#analytics-detail" class="rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 w-8 py-1.5 text-xs font-medium text-gray-300 text-center"><%= _ctotalPages %></button>
        <% } %>

        <% if (clicksPage < _ctotalPages) { %>
        <button hx-get="/admin/analytics/<%= url.id %>?clicksPage=<%= clicksPage + 1 %>&clicksLimit=<%= clicksLimit %>" hx-target="#panel" hx-swap="innerHTML" hx-select="#analytics-detail" class="flex items-center gap-1 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 px-3 py-1.5 text-xs font-medium text-gray-300 hover:text-white transition-colors">
          Next <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
        <% } %>
      </div>
    </div>
    <% } %>
  </div>
</div>