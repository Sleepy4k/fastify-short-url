<div
  id="qr-modal"
  class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/80 backdrop-blur-sm p-4"
  onclick="if (event.target.id === 'qr-modal') this.remove();"
>
  <div
    class="bg-gray-900 border border-gray-700 rounded-2xl p-6 w-full max-w-xs text-center shadow-2xl"
    onclick="event.stopPropagation()"
  >
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-bold text-gray-100">QR Code</h3>
      <button
        onclick="document.getElementById('qr-modal').remove()"
        class="text-gray-500 hover:text-gray-300 transition-colors"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>
    <p
      class="text-xs text-gray-400 mb-4 break-all bg-gray-800 rounded-lg px-3 py-2"
    >
      <%= shortUrl %>
    </p>
    <div class="flex justify-center mb-4">
      <img
        src="<%= qrDataUrl %>"
        alt="QR Code untuk <%= shortUrl %>"
        class="rounded-xl border-4 border-white shadow-lg"
        width="240"
        height="240"
      />
    </div>
    <div class="flex gap-2 justify-center">
      <a
        href="<%= qrDataUrl %>"
        download="qr-<%= shortUrl.split('/').pop() %>.png"
        class="rounded-xl px-4 py-2 text-xs font-semibold text-white transition-all hover:brightness-110 active:scale-95"
        style="background: linear-gradient(135deg, #cc0000, #990000)"
      >
        Unduh PNG
      </a>
      <button
        onclick="document.getElementById('qr-modal').remove()"
        class="rounded-xl bg-gray-700 hover:bg-gray-600 px-4 py-2 text-xs font-semibold transition-colors"
      >
        Tutup
      </button>
    </div>
  </div>
</div>
