<!-- QR Code Modal Partial -->
<div
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm"
  hx-on:click="if(event.target === this) this.remove()"
  id="qr-modal"
>
  <div class="bg-gray-900 border border-gray-700 rounded-2xl p-6 w-80 text-center shadow-2xl">
    <h3 class="text-sm font-semibold text-gray-200 mb-4">QR Code</h3>
    <p class="text-xs text-gray-400 mb-3 break-all"><%= shortUrl %></p>
    <img src="<%= qrDataUrl %>" alt="QR Code" class="mx-auto rounded-lg" width="256" height="256" />
    <div class="mt-4 flex gap-2 justify-center">
      <a
        href="<%= qrDataUrl %>"
        download="qr-<%= shortUrl.split('/').pop() %>.png"
        class="rounded-lg bg-indigo-600 hover:bg-indigo-500 px-4 py-2 text-xs font-semibold transition-colors"
      >
        Download PNG
      </a>
      <button
        onclick="document.getElementById('qr-modal').remove()"
        class="rounded-lg bg-gray-700 hover:bg-gray-600 px-4 py-2 text-xs font-semibold transition-colors"
      >
        Close
      </button>
    </div>
  </div>
</div>
