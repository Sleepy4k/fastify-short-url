<tr id="setting-<%= setting.key %>" class="hover:bg-gray-900/40 transition-colors">
  <td class="px-4 py-3 font-medium text-gray-200 whitespace-nowrap"><%= setting.label %></td>
  <td class="px-4 py-3 text-xs text-gray-500 hide-sm max-w-[180px]"><%= setting.description ?? '' %></td>
  <td class="px-4 py-3">
    <% if (setting.type === 'boolean') { %>
    <form id="form-<%= setting.key %>" hx-patch="/admin/settings/<%= setting.key %>" hx-target="#setting-<%= setting.key %>" hx-swap="outerHTML">
      <input type="hidden" name="value" id="boolval-<%= setting.key %>" value="<%= setting.value %>" />
      <label class="inline-flex items-center gap-3 cursor-pointer select-none">
        <div class="relative">
          <input type="checkbox" class="sr-only peer" <%= setting.value === 'true' ? 'checked' : '' %> onchange="document.getElementById('boolval-<%= setting.key %>').value = this.checked ? 'true' : 'false'; htmx.trigger(this.closest('form'), 'submit');" />
          <div class="w-10 h-5 bg-gray-600 peer-checked:bg-red-700 rounded-full transition-colors"></div>
          <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow transition-transform peer-checked:translate-x-5"></div>
        </div>
        <span class="text-xs font-semibold <%= setting.value === 'true' ? 'text-red-300' : 'text-gray-500' %>">
          <%= setting.value === 'true' ? 'Aktif' : 'Nonaktif' %>
        </span>
      </label>
    </form>
    <% } else { %>
    <form hx-patch="/admin/settings/<%= setting.key %>" hx-target="#setting-<%= setting.key %>" hx-swap="outerHTML" class="flex gap-2">
      <input type="<%= setting.type === 'number' ? 'number' : 'text' %>" name="value" value="<%= setting.value %>" class="flex-1 min-w-0 rounded-xl bg-gray-800 border border-gray-700 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:border-transparent transition-all" onfocus="this.style.borderColor='#CC0000'; this.style.boxShadow='0 0 0 2px rgba(204,0,0,0.3)'" onblur="this.style.borderColor=''; this.style.boxShadow=''" />
      <button type="submit" class="px-3 py-1.5 rounded-xl text-xs font-semibold text-white transition-all hover:brightness-110 whitespace-nowrap" style="background: linear-gradient(135deg, #CC0000, #990000);">
        Simpan
      </button>
    </form>
    <% } %>
  </td>
</tr>