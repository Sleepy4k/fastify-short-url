<div class="space-y-6">
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
    <div class="rounded-xl bg-gradient-to-br from-gray-900 to-gray-950 border border-gray-800 p-4 sm:p-6 shadow-lg">
      <div class="flex items-start justify-between gap-2">
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Total Link</p>
          <p class="mt-2 text-2xl sm:text-3xl font-bold text-red-400"><%= totalUrls %></p>
        </div>
        <div class="inline-flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 bg-red-900/30 rounded-xl flex-shrink-0">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
        </div>
      </div>
    </div>
    <div class="rounded-xl bg-gradient-to-br from-gray-900 to-gray-950 border border-gray-800 p-4 sm:p-6 shadow-lg">
      <div class="flex items-start justify-between gap-2">
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Total Klik</p>
          <p class="mt-2 text-2xl sm:text-3xl font-bold text-green-400"><%= totalClicks %></p>
        </div>
        <div class="inline-flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 bg-green-900/30 rounded-xl flex-shrink-0">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
          </svg>
        </div>
      </div>
    </div>
    <div class="rounded-xl bg-gradient-to-br from-gray-900 to-gray-950 border border-gray-800 p-4 sm:p-6 shadow-lg">
      <div class="flex items-start justify-between gap-2">
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Unique Klik</p>
          <p class="mt-2 text-2xl sm:text-3xl font-bold text-blue-400"><%= uniqueClicks %></p>
        </div>
        <div class="inline-flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 bg-blue-900/30 rounded-xl flex-shrink-0">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
      </div>
    </div>
    <div class="col-span-2 sm:col-span-1 rounded-xl bg-gradient-to-br from-gray-900 to-gray-950 border border-gray-800 p-4 sm:p-6 shadow-lg flex items-center justify-center">
      <div class="text-center">
        <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold mb-1">Rata-rata Klik</p>
        <p class="text-2xl sm:text-3xl font-bold text-yellow-400">
          <%= totalUrls > 0 ? (totalClicks / totalUrls).toFixed(1) : '0' %>
        </p>
        <p class="text-xs text-gray-500 mt-1">per link</p>
      </div>
    </div>
  </div>

  <div class="rounded-xl border border-gray-800 overflow-hidden shadow-lg">
    <div class="bg-gray-900 px-4 sm:px-6 py-4 border-b border-gray-800 flex items-center justify-between">
      <h3 class="text-sm font-bold text-gray-100">🏆 Top 10 Shortlink</h3>
    </div>
    <div class="table-responsive">
      <table class="w-full text-sm min-w-[500px]">
        <thead class="bg-gray-950 text-gray-400 text-xs font-semibold uppercase">
          <tr>
            <th class="px-4 sm:px-6 py-3 text-left">#</th>
            <th class="px-4 sm:px-6 py-3 text-left">Shortcode</th>
            <th class="px-4 sm:px-6 py-3 text-left hide-sm">Tujuan</th>
            <th class="px-4 sm:px-6 py-3 text-right">Total Klik</th>
            <th class="px-4 sm:px-6 py-3 text-center">Detail</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% for (const [i, url] of topUrls.entries()) { %>
          <tr class="hover:bg-gray-900/50 transition-colors">
            <td class="px-4 sm:px-6 py-3 text-gray-500 text-xs font-mono"><%= i + 1 %></td>
            <td class="px-4 sm:px-6 py-3 font-mono font-semibold text-red-400">
              <a href="<%= baseUrl %>/<%= url.shortcode %>" target="_blank" rel="noopener" class="hover:underline">
                <%= url.shortcode %>
              </a>
            </td>
            <td class="px-4 sm:px-6 py-3 max-w-[200px] truncate text-gray-400 text-xs hide-sm"><%= url.originalUrl %></td>
            <td class="px-4 sm:px-6 py-3 text-right font-bold text-green-400"><%= url.totalClicks %></td>
            <td class="px-4 sm:px-6 py-3 text-center">
              <button hx-get="/admin/analytics/<%= url.id %>" hx-target="#panel" hx-swap="innerHTML" hx-push-url="/admin/analytics/<%= url.id %>" onclick="activateTab('analytics')" class="text-xs font-semibold text-red-400 hover:text-red-300 transition-colors px-2 py-1 rounded hover:bg-red-900/20">
                Detail
              </button>
            </td>
          </tr>
          <% } %>
          <% if (!topUrls.length) { %>
          <tr>
            <td colspan="5" class="px-6 py-10 text-center text-gray-500 text-sm">Belum ada data klik.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>