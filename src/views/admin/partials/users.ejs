<%
const _ufp = `search=${encodeURIComponent(search)}&sort=${sort}&limit=${limit}`;
const _utotalPages = Math.ceil(total / limit);
let _ustartPage = Math.max(1, page - 2);
let _uendPage = Math.min(_utotalPages, _ustartPage + 4);
if (_uendPage - _ustartPage < 4) _ustartPage = Math.max(1, _uendPage - 4);
%>

<div id="users-section" hx-get="/admin/users" hx-trigger="userCreated from:body, userDeleted from:body" hx-swap="outerHTML" hx-target="#users-section" class="space-y-5">
  <div class="rounded-xl border border-gray-800 bg-gray-900 p-5">
    <h2 class="text-xs font-bold uppercase tracking-widest mb-4 flex items-center gap-2" style="color: #CC0000;">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
      </svg>
      Tambah Admin
    </h2>
    <form hx-post="/admin/users" hx-target="#user-form-error" hx-swap="innerHTML" class="flex flex-col sm:flex-row gap-3">
      <input type="text" name="username" placeholder="Username" required class="input-focus flex-1 min-w-0 rounded-xl bg-gray-800 border border-gray-700 px-4 py-2.5 text-sm focus:outline-none transition-all text-gray-100 placeholder-gray-500" />
      <input type="password" name="password" placeholder="Password" required class="input-focus flex-1 min-w-0 rounded-xl bg-gray-800 border border-gray-700 px-4 py-2.5 text-sm focus:outline-none transition-all text-gray-100 placeholder-gray-500" />
      <button type="submit" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white hover:brightness-110 transition-all whitespace-nowrap flex items-center gap-2" style="background: linear-gradient(135deg, #CC0000, #990000);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Tambah
      </button>
    </form>
    <div id="user-form-error" class="mt-3"></div>
  </div>

  <form id="users-filter-form" hx-get="/admin/users" hx-target="#users-section" hx-select="#users-section" hx-swap="outerHTML" hx-push-url="true" class="flex flex-col sm:flex-row gap-2">
    <div class="relative flex-1">
      <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <input type="search" name="search" value="<%= search %>" placeholder="Cari username..." class="input-focus w-full rounded-xl bg-gray-800 border border-gray-700 pl-9 pr-4 py-2.5 text-sm focus:outline-none transition-all placeholder-gray-500 text-gray-100" />
    </div>
    <input type="hidden" name="sort" value="<%= sort %>" id="users-sort-input" />
    <input type="hidden" name="page" value="1" id="users-page-input" />
    <div class="flex gap-2 flex-shrink-0">
      <div class="relative">
        <select name="limit" class="appearance-none rounded-xl bg-gray-800 border border-gray-700 px-3 pr-8 py-2.5 text-sm text-gray-300 focus:outline-none cursor-pointer hover:bg-gray-700 transition-colors" onchange="submitUsersFilterForm()">
          <% for (const n of [10, 20, 50]) { %>
          <option value="<%= n %>" <%= limit === n ? 'selected' : '' %>><%= n %> / hal</option>
          <% } %>
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-2 flex items-center">
          <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
      <button type="submit" class="flex items-center gap-1.5 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 px-4 py-2.5 text-sm font-medium text-gray-300 hover:text-white transition-colors flex-shrink-0">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        Cari
      </button>
    </div>
  </form>

  <div class="flex items-center justify-between text-xs text-gray-500">
    <span>
      <% if (total === 0) { %>
      Tidak ada pengguna<% if (search) { %> untuk "<strong class="text-gray-400"><%= search %></strong>"<% } %>
      <% } else { %>
      Menampilkan <strong class="text-gray-300"><%= (page - 1) * limit + 1 %>–<%= Math.min(page * limit, total) %></strong> dari <strong class="text-gray-300"><%= total %></strong> pengguna
      <% } %>
    </span>
    <% if (search) { %>
    <button hx-get="/admin/users?sort=<%= sort %>&limit=<%= limit %>" hx-target="#users-section" hx-select="#users-section" hx-swap="outerHTML" hx-push-url="true" class="text-xs text-gray-500 hover:text-gray-300 flex items-center gap-1 transition-colors">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
      Hapus filter
    </button>
    <% } %>
  </div>

  <div class="rounded-xl border border-gray-800 shadow-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[440px]">
        <thead class="bg-gray-900 text-gray-400 uppercase text-xs font-semibold">
          <tr>
            <th class="px-4 py-3 text-left w-10">#</th>
            <th class="px-4 py-3 text-left">
              <button type="button" onclick="setUsersSort('username')" class="flex items-center gap-0.5 hover:text-gray-200 transition-colors">
                Username <span class="sort-icon" data-field="username"></span>
              </button>
            </th>
            <th class="px-4 py-3 text-left">
              <button type="button" onclick="setUsersSort('role')" class="flex items-center gap-0.5 hover:text-gray-200 transition-colors">
                Role <span class="sort-icon" data-field="role"></span>
              </button>
            </th>
            <th class="px-4 py-3 text-left hide-sm">
              <button type="button" onclick="setUsersSort('createdAt')" class="flex items-center gap-0.5 hover:text-gray-200 transition-colors">
                Dibuat <span class="sort-icon" data-field="createdAt"></span>
              </button>
            </th>
            <th class="px-4 py-3 text-right">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% if (!users || users.length === 0) { %>
          <tr>
            <td colspan="5" class="px-4 py-12 text-center text-gray-500 text-sm">
              <% if (search) { %>Tidak ada pengguna yang cocok dengan "<%= search %>".
              <% } else { %>Belum ada admin terdaftar.<% } %>
            </td>
          </tr>
          <% } else { users.forEach(function(u, i) { %>
          <tr class="hover:bg-gray-900/50 transition-colors">
            <td class="px-4 py-3 text-gray-600 text-xs font-mono"><%= (page - 1) * limit + i + 1 %></td>
            <td class="px-4 py-3 font-medium text-gray-100">
              <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-gray-400 flex-shrink-0">
                  <%= u.username.charAt(0).toUpperCase() %>
                </div>
                <%= u.username %>
                <% if (u.id === currentUserId) { %>
                <span class="text-xs text-gray-600 italic">(Anda)</span>
                <% } %>
              </div>
            </td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
              <%= u.role === 'superadmin' ? 'bg-red-900/40 text-red-300 border border-red-700/60' : 'bg-gray-700/60 text-gray-300 border border-gray-600/60' %>">
                <%= u.role %>
              </span>
            </td>
            <td class="px-4 py-3 text-xs text-gray-500 hide-sm">
              <%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) : '—' %>
            </td>
            <td class="px-4 py-3 text-right">
              <% if (u.id !== currentUserId) { %>
              <span id="del-user-<%= u.id %>" hx-delete="/admin/users/<%= u.id %>" hx-swap="none" hx-trigger="confirmed" class="hidden"></span>
              <button onclick="confirmDeleteUser(<%= u.id %>, '<%= u.username %>')" class="px-3 py-1.5 rounded-lg text-xs font-semibold text-red-400 hover:text-white hover:bg-red-900/30 border border-transparent hover:border-red-700 transition-all">
                Hapus
              </button>
              <% } else { %>
              <span class="text-xs text-gray-700 italic px-3">—</span>
              <% } %>
            </td>
          </tr>
          <% }) } %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (_utotalPages > 1) { %>
  <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
    <span class="text-xs text-gray-500">Halaman <strong class="text-gray-300"><%= page %></strong> dari <strong class="text-gray-300"><%= _utotalPages %></strong></span>
    <div class="flex items-center gap-1">
      <% if (page > 1) { %>
      <button hx-get="/admin/users?page=<%= page - 1 %>&<%= _ufp %>" hx-target="#users-section" hx-select="#users-section" hx-swap="outerHTML" hx-push-url="true" class="flex items-center gap-1 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 px-3 py-2 text-xs font-medium text-gray-300 hover:text-white transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg> Prev
      </button>
      <% } %>

      <% if (_ustartPage > 1) { %>
      <button hx-get="/admin/users?page=1&<%= _ufp %>" hx-target="#users-section" hx-select="#users-section" hx-swap="outerHTML" hx-push-url="true" class="rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 w-9 py-2 text-xs font-medium text-gray-300 hover:text-white transition-colors text-center">1</button>
      <% if (_ustartPage > 2) { %><span class="text-gray-600 px-1 text-xs">…</span><% } %>
      <% } %>

      <% for (let p = _ustartPage; p <= _uendPage; p++) { %>
      <button hx-get="/admin/users?page=<%= p %>&<%= _ufp %>" hx-target="#users-section" hx-select="#users-section" hx-swap="outerHTML" hx-push-url="true" class="rounded-lg border w-9 py-2 text-xs font-medium transition-colors text-center <%= p === page ? 'bg-red-700 border-red-600 text-white' : 'bg-gray-800 hover:bg-gray-700 border-gray-700 text-gray-300 hover:text-white' %>">
        <%= p %>
      </button>
      <% } %>

      <% if (_uendPage < _utotalPages) { %>
      <% if (_uendPage < _utotalPages - 1) { %><span class="text-gray-600 px-1 text-xs">…</span><% } %>
      <button hx-get="/admin/users?page=<%= _utotalPages %>&<%= _ufp %>" hx-target="#users-section" hx-select="#users-section" hx-swap="outerHTML" hx-push-url="true" class="rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 w-9 py-2 text-xs font-medium text-gray-300 hover:text-white transition-colors text-center"><%= _utotalPages %></button>
      <% } %>

      <% if (page < _utotalPages) { %>
      <button hx-get="/admin/users?page=<%= page + 1 %>&<%= _ufp %>" hx-target="#users-section" hx-select="#users-section" hx-swap="outerHTML" hx-push-url="true" class="flex items-center gap-1 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 px-3 py-2 text-xs font-medium text-gray-300 hover:text-white transition-colors">
        Next <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
      <% } %>
    </div>
  </div>
  <% } %>
</div>