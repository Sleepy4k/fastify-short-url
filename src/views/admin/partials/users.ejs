<div id="users-section" hx-get="/admin/users" hx-trigger="userCreated from:body, userDeleted from:body" hx-swap="outerHTML" hx-target="#users-section">
  <div class="rounded-2xl border border-gray-700/50 bg-gray-800/60 backdrop-blur p-6 mb-6">
    <h2 class="text-sm font-bold uppercase tracking-widest mb-4" style="color: #CC0000;">Tambah Admin</h2>
    <form hx-post="/admin/users" hx-target="#user-form-error" hx-swap="innerHTML" class="flex flex-col sm:flex-row gap-3">
      <input type="text" name="username" placeholder="Username" required class="flex-1 min-w-0 rounded-xl bg-gray-900 border border-gray-700 px-4 py-2.5 text-sm focus:outline-none transition-all" onfocus="this.style.borderColor='#CC0000'; this.style.boxShadow='0 0 0 2px rgba(204,0,0,0.25)'" onblur="this.style.borderColor=''; this.style.boxShadow=''" />
      <input type="password" name="password" placeholder="Password" required class="flex-1 min-w-0 rounded-xl bg-gray-900 border border-gray-700 px-4 py-2.5 text-sm focus:outline-none transition-all" onfocus="this.style.borderColor='#CC0000'; this.style.boxShadow='0 0 0 2px rgba(204,0,0,0.25)'" onblur="this.style.borderColor=''; this.style.boxShadow=''" />
      <button type="submit" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white hover:brightness-110 transition-all whitespace-nowrap" style="background: linear-gradient(135deg, #CC0000, #990000);">
        Tambah
      </button>
    </form>
    <div id="user-form-error" class="mt-3"></div>
  </div>

  <div class="rounded-2xl border border-gray-700/50 bg-gray-800/60 backdrop-blur overflow-hidden">
    <div class="table-responsive">
      <table class="w-full text-sm" style="min-width: 440px;">
        <thead>
          <tr class="border-b border-gray-700/60 text-left">
            <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">#</th>
            <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Username</th>
            <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Role</th>
            <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 hide-sm">Dibuat</th>
            <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 text-right">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-700/40">
          <% if (!users || users.length === 0) { %>
          <tr>
            <td colspan="5" class="px-4 py-8 text-center text-gray-500 text-sm">Belum ada admin terdaftar.</td>
          </tr>
          <% } else { users.forEach(function(u, i) { %>
          <tr class="hover:bg-gray-900/40 transition-colors">
            <td class="px-4 py-3 text-gray-500 text-xs"><%= i + 1 %></td>
            <td class="px-4 py-3 font-medium text-gray-100"><%= u.username %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                <%= u.role === 'superadmin' ? 'bg-red-900/40 text-red-300 border border-red-700/60' : 'bg-gray-700/60 text-gray-300 border border-gray-600/60' %>">
                <%= u.role %>
              </span>
            </td>
            <td class="px-4 py-3 text-xs text-gray-500 hide-sm">
              <%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('id-ID') : '-' %>
            </td>
            <td class="px-4 py-3 text-right">
              <% if (u.id !== currentUserId) { %>
              <span id="del-user-<%= u.id %>" hx-delete="/admin/users/<%= u.id %>" hx-swap="none" hx-trigger="confirmed" class="hidden"></span>
              <button onclick="confirmDeleteUser(<%= u.id %>, '<%= u.username %>')" class="px-3 py-1.5 rounded-lg text-xs font-semibold text-red-400 hover:text-white hover:bg-red-900/30 border border-transparent hover:border-red-700 transition-all">
                Hapus
              </button>
              <% } else { %>
              <span class="text-xs text-gray-600 italic">Anda</span>
              <% } %>
            </td>
          </tr>
          <% }) } %>
        </tbody>
      </table>
    </div>
  </div>
</div>