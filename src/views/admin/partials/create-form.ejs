<section class="mb-6 rounded-2xl border border-gray-800 bg-gray-900/60 backdrop-blur-sm p-5 sm:p-6 shadow-xl">
  <div class="flex items-center gap-3 mb-5">
    <div class="inline-flex items-center justify-center w-10 h-10 rounded-xl flex-shrink-0" style="background: linear-gradient(135deg, #cc0000, #990000)">
      <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
      </svg>
    </div>
    <div>
      <h2 class="text-base font-bold text-gray-100">Buat Shortlink Baru</h2>
      <p class="text-xs text-gray-400 mt-0.5">
        Pangkas URL panjang menjadi link yang mudah dibagikan
      </p>
    </div>
  </div>

  <div id="create-error" class="mb-4"></div>

  <form hx-post="/admin/urls" hx-target="#create-error" hx-swap="innerHTML" hx-on::after-request="if(event.detail.successful && event.detail.xhr.status===201) { this.reset(); }" class="space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <label class="block text-xs font-semibold text-gray-300 mb-1.5">
          URL Tujuan <span class="text-red-400">*</span>
        </label>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <input name="originalUrl" type="url" required placeholder="https://example.com/your/very/long/url/here" class="input-focus w-full rounded-xl bg-gray-800/80 border border-gray-700 pl-9 pr-4 py-2.5 text-sm focus:outline-none transition-all placeholder-gray-500" />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-xs font-semibold text-gray-300 mb-1.5">
          Alias Kustom
          <span class="text-gray-500 font-normal">(opsional)</span>
        </label>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <span class="text-gray-500 text-xs">/</span>
          </div>
          <input name="customAlias" type="text" placeholder="contoh-link" pattern="[a-zA-Z0-9_\-]+" class="input-focus w-full rounded-xl bg-gray-800/80 border border-gray-700 pl-6 pr-4 py-2.5 text-sm focus:outline-none transition-all placeholder-gray-500" />
        </div>
        <p class="text-xs text-gray-500 mt-1">Huruf, angka, - dan _ saja</p>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-300 mb-1.5">
          Tanggal Kadaluarsa
          <span class="text-gray-500 font-normal">(opsional)</span>
        </label>
        <input name="expiresAt" type="datetime-local" class="input-focus w-full rounded-xl bg-gray-800/80 border border-gray-700 px-3 py-2.5 text-sm focus:outline-none transition-all" />
      </div>

      <div class="flex items-end lg:mb-5 md:mb-5 lg:mt-0 mt-2">
        <button type="submit" class="w-full rounded-xl px-4 py-2.5 text-sm font-semibold text-white transition-all hover:shadow-lg hover:brightness-110 active:scale-95 inline-flex items-center justify-center gap-2" style="background: linear-gradient(135deg, #cc0000, #990000)">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Buat Shortlink
        </button>
      </div>
    </div>

    <!-- Advanced Options -->
    <details class="group">
      <summary class="flex items-center gap-2 text-xs font-semibold text-gray-400 hover:text-gray-200 cursor-pointer select-none list-none py-1 transition-colors">
        <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        Opsi Lanjutan (SEO &amp; Password)
      </summary>
      <div class="mt-3 space-y-4 border-t border-gray-800 pt-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1.5">
              Judul SEO
              <span class="text-gray-500 font-normal">(opsional)</span>
            </label>
            <input name="title" type="text" placeholder="Judul untuk preview media sosial" maxlength="255" class="input-focus w-full rounded-xl bg-gray-800/80 border border-gray-700 px-4 py-2.5 text-sm focus:outline-none transition-all placeholder-gray-500" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1.5">
              URL Gambar OG
              <span class="text-gray-500 font-normal">(opsional)</span>
            </label>
            <input name="ogImageUrl" type="url" placeholder="https://example.com/image.jpg" class="input-focus w-full rounded-xl bg-gray-800/80 border border-gray-700 px-4 py-2.5 text-sm focus:outline-none transition-all placeholder-gray-500" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs font-semibold text-gray-300 mb-1.5">
              Deskripsi SEO
              <span class="text-gray-500 font-normal">(opsional)</span>
            </label>
            <textarea name="description" rows="2" placeholder="Deskripsi singkat untuk preview media sosial" class="input-focus w-full rounded-xl bg-gray-800/80 border border-gray-700 px-4 py-2.5 text-sm focus:outline-none transition-all placeholder-gray-500 resize-none"></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1.5">
              Password Proteksi
              <span class="text-gray-500 font-normal">(opsional)</span>
            </label>
            <input name="password" type="password" placeholder="Biarkan kosong jika tidak ingin proteksi" autocomplete="new-password" class="input-focus w-full rounded-xl bg-gray-800/80 border border-gray-700 px-4 py-2.5 text-sm focus:outline-none transition-all placeholder-gray-500" />
            <p class="text-xs text-gray-500 mt-1">Pengunjung harus memasukkan password sebelum diarahkan</p>
          </div>
        </div>
      </div>
    </details>
  </form>
</section>