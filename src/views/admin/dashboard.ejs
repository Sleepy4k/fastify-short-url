<!DOCTYPE html>
<html lang="id" class="bg-gray-950">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — <%= appName %></title>
  <meta name="htmx-config" content='{"timeout":10000}' />
  <link rel="stylesheet" href="/assets/css/app.css" />
  <link rel="stylesheet" href="/assets/css/dashboard.css" />
  <script src="/assets/js/tailwind.cdn.js"></script>
  <script src="/assets/js/htmx.min.js" defer></script>
</head>

<body class="min-h-screen bg-gray-950 text-gray-100">
  <div id="logout-modal" class="hidden fixed inset-0 z-[80] flex items-center justify-center">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="document.getElementById('logout-modal').classList.add('hidden')"></div>
    <div class="relative bg-gray-900 rounded-2xl border border-gray-700 shadow-2xl p-8 max-w-sm w-full mx-4 text-center">
      <div class="inline-flex items-center justify-center w-14 h-14 bg-red-900/40 border border-red-700 rounded-full mb-4">
        <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-white mb-2">Keluar dari Dashboard?</h2>
      <p class="text-sm text-gray-400 mb-6">Anda akan diarahkan ke halaman login.</p>
      <div class="flex gap-3 justify-center">
        <button onclick="document.getElementById('logout-modal').classList.add('hidden')" class="px-5 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-sm font-medium transition-colors">Batal</button>
        <form method="POST" action="/logout" class="inline">
          <button type="submit" class="px-5 py-2 rounded-lg bg-red-700 hover:bg-red-600 text-sm font-medium text-white transition-colors">Ya, Keluar</button>
        </form>
      </div>
    </div>
  </div>

  <div id="confirm-modal" class="hidden fixed inset-0 z-[80] flex items-center justify-center">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeConfirmModal()"></div>
    <div class="relative bg-gray-900 rounded-2xl border border-gray-700 shadow-2xl p-8 max-w-sm w-full mx-4 text-center">
      <div class="inline-flex items-center justify-center w-14 h-14 bg-red-900/40 border border-red-700 rounded-full mb-4">
        <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
        </svg>
      </div>
      <h2 id="confirm-modal-title" class="text-lg font-semibold text-white mb-2">Konfirmasi</h2>
      <p id="confirm-modal-message" class="text-sm text-gray-400 mb-6">Apakah Anda yakin?</p>
      <div class="flex gap-3 justify-center">
        <button onclick="closeConfirmModal()" class="px-5 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-sm font-medium transition-colors">Batal</button>
        <button id="confirm-modal-ok" class="px-5 py-2 rounded-lg bg-red-700 hover:bg-red-600 text-sm font-medium text-white transition-colors">Konfirmasi</button>
      </div>
    </div>
  </div>

  <nav class="border-b border-gray-800 bg-gray-900 px-4 sm:px-6 py-3 flex items-center justify-between sticky top-0 z-40 shadow-md">
    <div class="flex items-center gap-2 sm:gap-3 min-w-0">
      <div class="inline-flex items-center justify-center w-8 h-8 flex-shrink-0 rounded-lg" style="background: linear-gradient(135deg, #CC0000, #990000);">
        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
      </div>
      <span class="font-bold text-base text-white truncate"><%= appName %></span>
    </div>
    <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
      <% if (maintenanceMode) { %>
      <span class="hidden sm:inline-flex rounded-full bg-yellow-900/50 border border-yellow-700 px-3 py-1 text-xs font-medium text-yellow-200">🔧 Maintenance</span>
      <% } %>
      <span class="text-sm font-semibold text-gray-200 hidden sm:inline"><%= user.username %></span>
      <span class="text-xs font-medium text-gray-400 sm:hidden max-w-[80px] truncate"><%= user.username %></span>
      <button onclick="document.getElementById('logout-modal').classList.remove('hidden')" class="text-sm font-semibold text-gray-300 hover:text-red-400 px-3 py-1.5 rounded-lg hover:bg-gray-800 transition-colors border border-gray-700 hover:border-red-800">Logout</button>
    </div>
  </nav>

  <div class="border-b border-gray-800 bg-gray-900 sticky top-[49px] z-30">
    <nav class="tab-strip px-2 sm:px-6" aria-label="Tabs">
      <button data-tab="links" hx-get="/admin/links" hx-target="#panel" hx-swap="innerHTML" hx-push-url="true" onclick="activateTab('links')" class="tab-btn<%= tab === 'links' ? ' active' : '' %> px-3 sm:px-4 py-3 font-medium text-sm">Links</button>
      <button data-tab="analytics" hx-get="/admin/analytics" hx-target="#panel" hx-swap="innerHTML" hx-push-url="true" onclick="activateTab('analytics')" class="tab-btn<%= tab === 'analytics' ? ' active' : '' %> px-3 sm:px-4 py-3 font-medium text-sm">Analytics</button>
      <button data-tab="settings" hx-get="/admin/settings" hx-target="#panel" hx-swap="innerHTML" hx-push-url="true" onclick="activateTab('settings')" class="tab-btn<%= tab === 'settings' ? ' active' : '' %> px-3 sm:px-4 py-3 font-medium text-sm">Settings</button>
      <% if (user.role === 'superadmin') { %>
      <button data-tab="users" hx-get="/admin/users" hx-target="#panel" hx-swap="innerHTML" hx-push-url="true" onclick="activateTab('users')" class="tab-btn<%= tab === 'users' ? ' active' : '' %> px-3 sm:px-4 py-3 font-medium text-sm">Users</button>
      <% } %>
      <button data-tab="profile" hx-get="/admin/profile" hx-target="#panel" hx-swap="innerHTML" hx-push-url="true" onclick="activateTab('profile')" class="tab-btn<%= tab === 'profile' ? ' active' : '' %> px-3 sm:px-4 py-3 font-medium text-sm">Profil</button>
    </nav>
  </div>

  <main class="p-3 sm:p-6 max-w-7xl mx-auto">
    <div id="panel"><%- panelHtml %></div>
  </main>

  <div id="modal-container" class="z-[9999]"></div>

  <script>
    function activateTab(name) {
      document.querySelectorAll('[data-tab]').forEach(function(el) {
        el.classList.toggle('active', el.dataset.tab === name);
      });
    }

    var toastContainer = (function() {
      var c = document.createElement('div');
      c.className = 'fixed top-4 right-4 z-[100] flex flex-col gap-2 items-end pointer-events-none';
      document.body.appendChild(c);
      return c;
    })();

    function showToast(msg, type) {
      var el = document.createElement('div');
      el.textContent = msg;
      var base = 'max-w-xs sm:max-w-sm px-4 py-3 rounded-xl text-sm font-semibold shadow-2xl border select-none transition-opacity duration-300 opacity-0';
      var colors = type === 'success' ?
        ' bg-green-900 border-green-700 text-green-200' :
        type === 'error' ?
        ' bg-red-900 border-red-700 text-red-200' :
        ' bg-gray-800 border-gray-600 text-gray-200';
      el.className = base + colors;
      toastContainer.appendChild(el);
      requestAnimationFrame(function() {
        el.style.opacity = '1';
      });
      setTimeout(function() {
        el.style.opacity = '0';
        setTimeout(function() {
          el.remove();
        }, 300);
      }, 3500);
    }

    document.body.addEventListener('showToast', function(evt) {
      var d = evt.detail;
      if (d && d.message) showToast(d.message, d.type || 'success');
    });

    function showConfirmModal(opts) {
      document.getElementById('confirm-modal-title').textContent = opts.title || 'Konfirmasi';
      document.getElementById('confirm-modal-message').textContent = opts.message || 'Apakah Anda yakin?';
      var ok = document.getElementById('confirm-modal-ok');
      ok.textContent = opts.confirmText || 'Konfirmasi';
      ok.className = 'px-5 py-2 rounded-lg text-sm font-medium text-white transition-colors ' + (opts.okClass || 'bg-red-700 hover:bg-red-600');
      ok.onclick = function() {
        closeConfirmModal();
        if (opts.onConfirm) opts.onConfirm();
      };
      document.getElementById('confirm-modal').classList.remove('hidden');
    }

    function closeConfirmModal() {
      document.getElementById('confirm-modal').classList.add('hidden');
    }

    function confirmDeleteUrl(id, shortcode) {
      showConfirmModal({
        title: 'Hapus Shortlink',
        message: 'Yakin ingin menghapus "/' + shortcode + '"? Semua data analytics akan ikut terhapus secara permanen dan tidak dapat dikembalikan.',
        confirmText: 'Ya, Hapus',
        onConfirm: function() {
          var el = document.getElementById('del-url-' + id);
          if (el) htmx.trigger(el, 'confirmed');
        }
      });
    }

    function confirmDeleteUser(id, username) {
      showConfirmModal({
        title: 'Hapus Pengguna',
        message: 'Yakin ingin menghapus pengguna "' + username + '"? Tindakan ini tidak dapat dibatalkan.',
        confirmText: 'Ya, Hapus',
        onConfirm: function() {
          var el = document.getElementById('del-user-' + id);
          if (el) htmx.trigger(el, 'confirmed');
        }
      });
    }

    function confirmResetAnalytics(urlId, shortcode) {
      showConfirmModal({
        title: 'Reset Analytics',
        message: 'Reset semua data analytics untuk "/' + shortcode + '"? Data klik, IP, dan riwayat akses akan dihapus permanen dan tidak dapat dipulihkan.',
        confirmText: 'Ya, Reset',
        okClass: 'bg-yellow-700 hover:bg-yellow-600',
        onConfirm: function() {
          var el = document.getElementById('reset-analytics-' + urlId);
          if (el) htmx.trigger(el, 'confirmed');
        }
      });
    }

    document.addEventListener('htmx:pushedIntoHistory', function() {
      var map = {
        '/admin/links': 'links',
        '/admin/analytics': 'analytics',
        '/admin/settings': 'settings',
        '/admin/users': 'users',
        '/admin/profile': 'profile'
      };
      var p = window.location.pathname;
      var t = map[p] || (p.startsWith('/admin/analytics/') ? 'analytics' : null);
      if (t) activateTab(t);
    });
  </script>
</body>

</html>