# Application
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=shorturl
DB_PASSWORD=your_strong_password
DB_NAME=shorturl

# Redis
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=
REDIS_TLS=false
REDIS_FAMILY=4
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_TTL=3600

# Misc
JWT_SECRET=change_this_to_a_long_random_secret_value_at_least_64_chars
COOKIE_SECRET=change_this_to_another_long_random_secret_for_cookie_signing
